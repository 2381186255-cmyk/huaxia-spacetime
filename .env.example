# 华夏时空 - 环境变量示例
# 复制此文件为 .env.local 并填入实际值

# 数据库（可选，Mock模式不需要）
DATABASE_URL=postgresql://user:password@localhost:5432/huaxia_spacetime

# Redis（可选，Mock模式不需要）
REDIS_URL=redis://localhost:6379

# 外部API（可选，Mock模式不需要）
CHGIS_API_URL=https://chgis.fas.harvard.edu/api
CHGIS_API_KEY=
CBDB_API_URL=https://cbdb.fas.harvard.edu/api
CTEXT_API_URL=https://ctext.org/tools/api
CHRONOLOGY_API_URL=

# CCTS WMTS 古地图瓦片服务（开源学术资源）
CCTS_WMTS_URL=https://gis.sinica.edu.tw/ccts/wmts
CCTS_WMTS_KEY=

# MapLibre（可选，使用CARTO免费底图不需要key）
NEXT_PUBLIC_MAPTILER_KEY=

# FastAPI后端（可选）
FASTAPI_URL=http://localhost:8000

# 应用
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mock模式（无数据库时使用本地数据，设为true即可独立运行）
USE_MOCK=true
